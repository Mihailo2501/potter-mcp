# Provider tokens (BYOK, no Potter-operated proxy)
POTTER_APIFY_TOKEN=
POTTER_FIRECRAWL_API_KEY=
POTTER_BROWSERBASE_API_KEY=
POTTER_BROWSERBASE_PROJECT_ID=
POTTER_ANTHROPIC_API_KEY=
POTTER_OPENAI_API_KEY=

# Runtime tuning
POTTER_MAX_RESPONSE_BYTES=20000
POTTER_LOG_LEVEL=info
POTTER_PROVIDER_TIMEOUT_MS=60000
POTTER_MAX_RETRIES=3
POTTER_CONCURRENCY_LIMIT=5
POTTER_BROWSER_SESSION_TIMEOUT_MINUTES=10
POTTER_BROWSER_ACT_MAX_STEPS=10
POTTER_BROWSER_ACT_TIMEOUT_SECONDS=120

# Apify actor IDs (populate after scripts/benchmark-actors.ts run)
POTTER_APIFY_LINKEDIN_PROFILE_ACTOR=
POTTER_APIFY_LINKEDIN_COMPANY_ACTOR=
POTTER_APIFY_LINKEDIN_POSTS_ACTOR=
POTTER_APIFY_LINKEDIN_EMPLOYEES_ACTOR_INTERNAL=

# Feature flags
POTTER_ENABLE_EXPERIMENTAL_BROWSER_ACT=true
POTTER_ALLOW_PRIVATE_URLS=false
POTTER_ENABLE_PING=false
